{
  "name": "raj-enterprises",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@raj-enterprises/web",
    "dev:admin": "turbo run dev --filter=@raj-enterprises/admin",
    "dev:api": "cd apps/api && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@raj-enterprises/web",
    "build:admin": "turbo run build --filter=@raj-enterprises/admin",
    "lint": "turbo run lint",
    "seed": "cd apps/api && python -m app.seed",
    "test:api": "cd apps/api && pytest"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0"
}
