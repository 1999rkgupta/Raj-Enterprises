# ===== Raj Enterprises API — Environment Variables =====

# --- Application ---
APP_NAME=Raj Enterprises API
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=raj_enterprises

# --- Firebase ---
# Download your Firebase Admin SDK service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Image Storage ---
# Base URL for resolving product image paths.
# For local dev: http://localhost:5173/uploads
# For production: https://cdn.rajenterprises.com or S3 bucket URL
IMAGE_BASE_URL=http://localhost:5173/uploads
IMAGE_UPLOAD_DIR=../web/public/uploads

# --- Security ---
# Max admin accounts allowed (excluding super_admin)
MAX_ADMIN_ACCOUNTS=5
# OTP rate limit: max requests per IP per minute
OTP_RATE_LIMIT=5
# Login rate limit: max failed attempts per IP per 15 minutes
LOGIN_RATE_LIMIT=10
# Session inactivity timeout in days
SESSION_INACTIVITY_DAYS=10
# Session max lifetime in days
SESSION_MAX_LIFETIME_DAYS=30

# --- Order Defaults ---
DEFAULT_DELIVERY_DAYS=7

# --- PDF/Invoice ---
COMPANY_NAME=Raj Enterprises
COMPANY_ADDRESS=Your Company Address Here
COMPANY_PHONE=+91-XXXXXXXXXX
COMPANY_EMAIL=info@rajenterprises.com
COMPANY_GST=XXXXXXXXXXXX
